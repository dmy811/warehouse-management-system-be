# Environment
APP_ENV=development
RUST_LOG=warn,warehouse_management_system_backend=info

# Server
HOST=0.0.0.0
PORT=8080
WORKERS=4

# Database
DATABASE_URL=postgresql://postgres:postgress@localhost:5432/warehouse-axum
DATABASE_POOL_SIZE=50
DATABASE_TIMEOUT_SECONDS=5

# Redis
REDIS_URL=redis://redis-1.internal:6379
REDIS_POOL_SIZE=20
REDIS_TIMEOUT_SECONDS=2
USE_REDIS_CACHE=true

PASETO_SYMMETRIC_KEY=
REFRESH_TOKEN_HMAC_SECRET=
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_TOKEN_LENGTH_BYTES=32

COOKIE_NAME="__Secure_refresh_token"
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE="Strict"
COOKIE_DOMAIN=".example.com"
COOKIE_PATH="/api/v1/auth/refresh"
COOKIE_MAX_AGE_SECONDS=604800

CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

RATE_LIMIT_PER_IP=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=150

FAILED_LOGIN_THRESHOLD=5
FAILED_LOGIN_LOCKOUT_MINUTES=15

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=